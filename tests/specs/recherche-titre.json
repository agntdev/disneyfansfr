[
  {
    "name": "/recherche with query shows results",
    "steps": [
      {
        "send": { "text": "/recherche Lion" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🔍 Résultats (1) :\n\n1. 🎬 <b>Le Roi Lion</b> (1994)"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/recherche without query asks for input",
    "steps": [
      {
        "send": { "text": "/recherche" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🔍 Tape le nom d'un film ou d'une série Disney :"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "search menu button asks for input",
    "steps": [
      {
        "send": { "callback": "recherche:menu" },
        "expect": [{ "method": "editMessageText" }]
      }
    ]
  }
]
